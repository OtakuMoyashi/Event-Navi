generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
generator zod {
  provider = "prisma-zod-generator"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String     @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(false)
  startedAt   DateTime
  finishedAt  DateTime
  description String?

  stores  Store[]
  admins  Admin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

enum StoreType {
  ATTRACTION
  FOOD
}

model Store {
  id          String     @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(false)
  startedAt   DateTime?
  finishedAt  DateTime?
  description String?

  storeType StoreType

  attraction Attraction?
  food Food?

  event   Event?   @relation(fields: [eventId], references: [id])
  eventId String?

  admins Admin[]
  staffs  Staff[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

model Attraction {
  id String @id @default(cuid())

  storeId String @unique
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attracions")
}

model Food {
  id String @id @default(cuid())

  storeId String @unique
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("foods")
}

enum TicketStatus {
  ISSUED
  CALLED
  COMPLETED
  CANCELLED
}

model Ticket {
  id   String    @id @default(cuid())

  index          Int
  numberOfPeople Int
  status         TicketStatus @default(ISSUED)

  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id])

  userId  String
  user    User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model User {
  id   String    @id @default(cuid())

  tickets           Ticket[]
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model PushSubscription {
  id       String    @id @default(cuid())
  endpoint String @unique
  p256dh   String
  auth     String

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("push_subscriptions")
}

model Admin {
  id        String    @id @default(cuid())
  supabaseUserId String @unique

  email     String    @unique
  name      String?
  role      AdminRole

  eventId   String?   
  event     Event?    @relation(fields: [eventId], references: [id])
  
  storeId   String?   
  store     Store?    @relation(fields: [storeId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admins")
}

enum AdminRole {
  EVENT_ADMIN
  STORE_ADMIN
}

model Staff {
  id        String    @id @default(cuid())
  supabaseUserId String @unique

  email   String    @unique
  
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("staffs")
}
