{
  "name": "gakusai-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- next dev",
    "test": "dotenv -e .env.test -- next dev",
    "build": "dotenv -e .env.local -- next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local drizzle-kit generate",
    "db:push": "dotenv -e .env.local  drizzle-kit push",
    "db:migrate": "dotenv -e .env.local drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local drizzle-kit studio",
    "db:migrate:test": "dotenv -e .env.test -- drizzle-kit migrate dev",
    "better-auth:migrate": "dotenv -e .env.local -- @better-auth/cli migrate"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "better-auth": "^1.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.4",
    "react-zxing": "^2.1.0",
    "server-only": "^0.0.1",
    "supabase": "^2.76.14",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
